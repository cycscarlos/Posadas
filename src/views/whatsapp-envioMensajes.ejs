    <script>
      async function enviarMensaje(event) {
        event.preventDefault();
        const mensaje = document.getElementById("mensaje").value;
        const seleccioneTodos =
          document.getElementById("seleccioneTodos").checked;

        // Cambia a 'telefono'
        const telefonoSeleccionado =
          document.getElementById("telefonoSelect").value;

        const response = await fetch("/whatsapp-envioMensajes", {
          // Asegúrate de que la URL sea correcta
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            mensaje: mensaje,
            seleccioneTodos: seleccioneTodos,
            telefono: telefonoSeleccionado, // Cambiado para usar 'telefono'
          }),
        });

        if (response.ok) {
          // Lógica si el mensaje se envía correctamente
          alert("Mensaje enviado con éxito");
        } else {
          // Manejo del error
          alert("Error al enviar el mensaje");
        }
      }
    </script>
    <!-- Función para busqueda selectiva por nombre dentro de la BDD -->
    <script>
      function toggleSelect() {
        const select = document.getElementById("telefonoSelect");
        const search = document.getElementById("search");
        const seleccioneTodos =
          document.getElementById("seleccioneTodos").checked;

        if (seleccioneTodos) {
          // Limpiar el campo de búsqueda y el select
          search.value = "";
          select.selectedIndex = 0; // Reinicia a la opción por defecto
          // Desactivar el campo de búsqueda
          search.disabled = true;
          select.disabled = true; // Desactiva el select
        } else {
          // Activar el campo de búsqueda y el select
          search.disabled = false;
          select.disabled = false;
        }
      }
      function filterClientes() {
        const input = document.getElementById("search").value.toLowerCase();
        const select = document.getElementById("telefonoSelect");
        const options = select.options;

        let found = false;

        for (let i = 0; i < options.length; i++) {
          const option = options[i];
          const nombreCompleto = `${option.getAttribute(
            "data-nombre"
          )} ${option.getAttribute("data-apellido")}`.toLowerCase();
          option.style.display = nombreCompleto.includes(input)
            ? "block"
            : "none";
          if (nombreCompleto.includes(input)) found = true;
        }

        // Si no se encontró, se puede manejar de alguna forma, como sugerir el nombre o limpiar el select
        if (!found) {
          select.selectedIndex = 0; // Reinicia la selección si no se encuentra
        }
      }
    </script>
  </head>
  <body>
    <%- include('../../public/components/header.html') %>

    <h1 class="title-whatsapp">Publicidad por WhatsApp</h1>
    <form id="whatsappForm" onsubmit="enviarMensaje(event)" class="form">
      <div class="inputBx">
        <textarea
          id="mensaje"
          rows="4"
          placeholder="Ingresa el mensaje..."
          required
        ></textarea>
      </div>

      <!-- search -->
      <div class="inputBx">
        <label for="search">Buscar Cliente:</label>
        <input
          type="text"
          id="search"
          placeholder="Buscar por nombre..."
          onkeyup="filterClientes()"
          class="input"
        />
      </div>

      <!-- select -->
      <div class="inputBx">
        <label for="telefonoSelect">Seleccionar Cliente:</label>
        <select id="telefonoSelect" class="input">
          <option value="">-- Seleccionar --</option>
          <% clientes.forEach(cliente => { %>
          <option
            value="<%= cliente.telefono %>"
            data-nombre="<%= cliente.nombre %>"
            data-apellido="<%= cliente.apellido %>"
          >
            <%= cliente.nombre %> <%= cliente.apellido %>
          </option>
          <% }) %>
        </select>
      </div>

      <!-- Checkbox -->
      <div class="inputBx">
        <label>
          <input
            type="checkbox"
            id="seleccioneTodos"
            class="input"
            onclick="toggleSelect()"
          />
          Seleccionar todos los clientes
        </label>
      </div>

      <!-- botón de enviar -->
      <button type="submit" class="btn">Enviar Mensajes</button>
    </form>

    <!-- Footer -->

    <%- include('../../public/components/footer.html') %>
  </body>
</html>
