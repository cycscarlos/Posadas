<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="shortcut icon" href="../img/favicon.png" type="image/x-icon" />
    <title>Enviar Mensajes por WhatsApp</title>
    <link rel="stylesheet" href="../css/main.css" />
    <link rel="stylesheet" href="../css/responsive-base.css" />
    <link rel="stylesheet" href="../css/navbar.css" />
    <link rel="stylesheet" href="../css/enviar-correo.css" />
    <link rel="stylesheet" href="../css/copyright.css" />

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.12.4/dist/sweetalert2.all.min.js"></script>

    <style>
      .test-mode-banner {
        background-color: #FFC107;
        color: #000;
        text-align: center;
        padding: 10px;
        margin-bottom: 20px;
        border-radius: 5px;
        font-weight: bold;
        animation: pulse 2s infinite;
      }
      @keyframes pulse {
        0% { opacity: 0.8; }
        50% { opacity: 1; }
        100% { opacity: 0.8; }
      }
    </style>

    <script>
      async function enviarMensaje(event) {
        event.preventDefault();

        Swal.fire({
          title: 'Enviando mensajes',
          text: 'Por favor espere...',
          allowOutsideClick: false,
          allowEscapeKey: false,
          didOpen: () => { Swal.showLoading(); }
        });

        const mensaje = document.getElementById("mensaje").value;
        const seleccioneTodos = document.getElementById("seleccioneTodos").checked;
        const telefonoSelect = document.getElementById("telefonoSelect");
        const telefono = seleccioneTodos ? null : telefonoSelect.value;

        if (!mensaje.trim()) {
          Swal.fire({ icon: 'error', title: 'Error', text: 'El mensaje no puede estar vacío' });
          return;
        }

        if (!seleccioneTodos && !telefono) {
          Swal.fire({ icon: 'error', title: 'Error', text: 'Debe seleccionar al menos un destinatario' });
          return;
        }

        try {
          const response = await fetch("/whatsapp-envioMensajes", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ mensaje, seleccioneTodos, telefono }),
          });

          const data = await response.json();

          if (response.ok && data.success) {
            Swal.fire({
              icon: 'success',
              title: '¡Éxito!',
              text: data.message,
              confirmButtonText: 'Ver detalles',
              showCancelButton: true,
              cancelButtonText: 'Cerrar'
            }).then((result) => {
              if (result.isConfirmed && data.detalles) {
                mostrarDetallesEnvio(data.detalles);
              }
            });
            document.getElementById("whatsappForm").reset();
            document.getElementById("telefonoSelect").disabled = false;
            document.getElementById("search").disabled = false;
          } else {
            Swal.fire({
              icon: 'error',
              title: 'Error',
              text: data.message || 'Error al enviar mensajes',
              confirmButtonText: 'Ver detalles',
              showCancelButton: true,
              cancelButtonText: 'Cerrar'
            }).then((result) => {
              if (result.isConfirmed && data.detalles) {
                mostrarDetallesEnvio(data.detalles);
              }
            });
          }
        } catch (error) {
          console.error("Error:", error);
          Swal.fire({ icon: 'error', title: 'Error', text: 'Error de conexión. Intente nuevamente.' });
        }
      }

      function mostrarDetallesEnvio(detalles) {
        let tabla = '<div style="max-height: 300px; overflow-y: auto;"><table style="width: 100%; border-collapse: collapse;">';
        tabla += '<thead><tr style="background-color: #f2f2f2;">';
        tabla += '<th style="padding: 8px; border: 1px solid #ddd;">Cliente</th>';
        tabla += '<th style="padding: 8px; border: 1px solid #ddd;">Teléfono</th>';
        tabla += '<th style="padding: 8px; border: 1px solid #ddd;">Estado</th>';
        tabla += '<th style="padding: 8px; border: 1px solid #ddd;">Detalles</th>';
        tabla += '</tr></thead><tbody>';

        detalles.forEach(d => {
          tabla += `<tr style="border: 1px solid #ddd;">`;
          tabla += `<td style="padding: 8px; border: 1px solid #ddd;">${d.nombre || 'N/A'}</td>`;
          tabla += `<td style="padding: 8px; border: 1px solid #ddd;">${d.telefono || 'N/A'}</td>`;
          if (d.enviado) {
            let estadoText = '✅ Enviado';
            if (d.simulado) estadoText += ' <small style="font-size: 11px; color: #555;">(simulado)</small>';
            tabla += `<td style="padding: 8px; border: 1px solid #ddd; color: green;">${estadoText}</td>`;
          } else {
            let estadoText = '❌ Fallido';
            if (d.simulado) estadoText += ' <small style="font-size: 11px; color: #555;">(simulado)</small>';
            tabla += `<td style="padding: 8px; border: 1px solid #ddd; color: red;">${estadoText}</td>`;
          }
          if (!d.enviado && d.error) {
            tabla += `<td style="padding: 8px; border: 1px solid #ddd; color: #d32f2f; font-size: 13px;">${d.error}</td>`;
          } else {
            tabla += `<td style="padding: 8px; border: 1px solid #ddd; color: #555;">Mensaje entregado correctamente</td>`;
          }
          tabla += `</tr>`;
        });
        tabla += '</tbody></table></div>';

        Swal.fire({ title: 'Detalles del envío', html: tabla, width: '800px', confirmButtonText: 'Cerrar' });
      }

      function toggleSelect() {
        const select = document.getElementById("telefonoSelect");
        const search = document.getElementById("search");
        const seleccioneTodos = document.getElementById("seleccioneTodos").checked;
        if (seleccioneTodos) {
          search.value = "";
          select.selectedIndex = 0;
          search.disabled = true;
          select.disabled = true;
        } else {
          search.disabled = false;
          select.disabled = false;
        }
      }

      function filterClientes() {
        const input = document.getElementById("search").value.toLowerCase();
        const select = document.getElementById("telefonoSelect");
        const options = select.options;
        let found = false;
        for (let i = 0; i < options.length; i++) {
          const option = options[i];
          const nombreCompleto = `${option.getAttribute("data-nombre")} ${option.getAttribute("data-apellido")}`.toLowerCase();
          const visible = nombreCompleto.includes(input);
          option.style.display = visible ? "block" : "none";
          if (visible && !found) found = true;
        }
        if (!found && input.trim() !== "") select.selectedIndex = 0;
      }
    </script>
    <meta name="csrf-token" content="<%= csrfToken %>">
  </head>
  <body>
    <%- include('../../public/components/header.html') %>

    <% if (locals.testMode) { %>
      <div class="test-mode-banner">
        <i class="fas fa-exclamation-triangle"></i>
        MODO DE PRUEBA - Los mensajes no serán enviados realmente
      </div>
    <% } %>

    <h1 class="title-whatsapp">Envío de Mensajes por WhatsApp</h1>
    <form id="whatsappForm" class="form">
      <div class="inputBx">
        <textarea
          id="mensaje"
          rows="4"
          placeholder="Ingresa el mensaje promocional aquí..."
          required
        ></textarea>
      </div>

      <div class="inputBx">
        <input
          type="text"
          id="search"
          placeholder="Buscar por nombre..."
          class="input"
        />
      </div>

      <div class="inputBx">
        <label for="telefonoSelect">Seleccionar Destinatario:</label>
        <select id="telefonoSelect" class="input">
          <option value="">-- Seleccionar --</option>
          <% clientes.forEach(cliente=> { %>
          <option
            value="<%= cliente.telefono %>"
            data-nombre="<%= cliente.nombre %>"
            data-apellido="<%= cliente.apellido %>"
          >
            <%= cliente.nombre %> <%= cliente.apellido %> - <%= cliente.telefono %>
          </option>
          <% }) %>
        </select>
      </div>

      <div>
        <label>
          <input
            type="checkbox"
            id="seleccioneTodos"
            class="input"
          />
          Seleccionar todos los destinatarios
        </label>
      </div>

      <button type="submit" class="btn">Enviar Mensajes</button>
    </form>

    <%- include('../../public/components/footer.html') %>
    <script>
      document.getElementById('whatsappForm').addEventListener('submit', enviarMensaje);
      document.getElementById('seleccioneTodos').addEventListener('click', toggleSelect);
      document.getElementById('search').addEventListener('keyup', filterClientes);
    </script>
    <script src="../js/csrf-injector.js"></script>
  </body>
</html>
