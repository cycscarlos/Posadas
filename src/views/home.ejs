<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Posada | Inicio</title>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
    />
    <link rel="shortcut icon" href="../img/favicon.png" type="image/x-icon" />
    <link rel="stylesheet" href="../css/home.css" />
    <link rel="preload" href="../img/beach.webp" as="image" />
    <style>
      #preloader {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: url("../img/beach.webp") no-repeat center center;
        background-size: cover;
        z-index: 1; 
        filter: blur(5px);
      }
      #video {
        display: none;
      }
    </style>
  </head>
  <body>
    <div id="preloader"></div>
    <section class="video-background">
      <video id="video" autoplay muted loop>
        <source src="../video/video4.mp4" type="video/mp4" />
      </video>
    </section>
    <div class="overlay-content">
      <header>
        <nav>
          <ul>
            <li>
              <i class="fa-solid fa-user"></i><a href="/login">INGRESAR</a>
            </li>
          </ul>
        </nav>
      </header>
      <main>
        <h1 class="title">¡Bienvenidos a tú POSADA!</h1>
        <p class="sub-title">Sistema de Administración de Reservaciones</p>
      </main>
      <footer class="footer">
        <p>
          Copyright &copy; Elaborado por
          <a href="https://cycs.netlify.app" target="_blank"
            >Carlos Colmenares A.</a> | Derechos Reservados
        </p>
      </footer>
    </div>

    <script src="../js/scrollreveal.min.js"></script>
    <script src="../js/scrollreveal.js"></script>
    <!-- // Espera a que el video se cargue completamente -->
    <script>      
      const video = document.getElementById("video");
      const preloader = document.getElementById("preloader");

      video.onloadeddata = function () {
        preloader.style.display = "none"; 
        video.style.display = "block";
      };
    </script>
  </body>
</html>
