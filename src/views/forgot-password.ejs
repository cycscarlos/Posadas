<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="shortcut icon" href="../img/favicon.png" type="image/x-icon" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <link rel="stylesheet" href="../css/login.css" />
    <link rel="stylesheet" href="../css/copyright.css" />
    <link rel="stylesheet" href="../css/responsive-base.css" />
    <link rel="preload" href="../img/posadaLobby.webp" as="image" />
    <title>Recuperar Contraseña | Posada</title>
    <meta name="csrf-token" content="<%= csrfToken %>">
</head>

<body>
    <%- include('../../public/components/login.html') %>

        <div class="fondo">
            <div class="contenedor-form login">
                <h2>Recuperar Contraseña</h2>
                <p class="instruccion">Ingresa tu nombre de usuario o correo electrónico para recibir un enlace de
                    recuperación.</p>
                <form action="/forgot-password" method="POST">
                    <div class="contenedor-input">
                        <span class="icono"><i class="fa-solid fa-user"></i></span>
                        <input type="text" required name="username" autocomplete="off" id="username" />
                        <label for="username">Usuario o Correo Electrónico</label>
                    </div>

                    <button type="submit" class="btn">Enviar Enlace</button>
                </form>

                <div class="volver">
                    <a href="/login">Volver a Iniciar Sesión</a>
                </div>
            </div>
        </div>
        <footer class="footer">
            <p>
                Copyright &copy; Elaborado por
                <a href="https://cycs.netlify.app" target="_blank">Carlos Colmenares A.</a> | Derechos Reservados
            </p>
        </footer>

        <!-- Sweetalert 2 -->
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.12.4/dist/sweetalert2.all.min.js"></script>

        <!-- Mensajes de alerta personalizados -->
        <% if (typeof alert !="undefined" ) { %>
            <script>
                Swal.fire({
                    title: "<%= alertTitle %>",
                    text: "<%= alertMessage %>",
                    icon: "<%= alertIcon %>",
                    showConfirmButton: true,
                    timer: 3000,
                }).then(() => {
                    window.location.href = "/<%= ruta %>";
                });
            </script>
            <% } %>
    <script src="../js/csrf-injector.js"></script>
</body>

</html>