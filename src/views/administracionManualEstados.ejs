<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="../img/favicon.png" type="image/x-icon" />
    <title>Administración Manual de Estados</title>
    <link rel="stylesheet" href="../css/main.css" />
    <link rel="stylesheet" href="../css/responsive-base.css" />
    <link rel="stylesheet" href="../css/navbar.css" />
    <link rel="stylesheet" href="../css/administracionManualEstados.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        .short-column {
            width: 50px;
        }

        .medium-column {
            width: 75px;
        }

        .full-column {
            width: 100px;
        }
    </style>
    <meta name="csrf-token" content="<%= csrfToken %>">
</head>

<body>

    <% if(typeof success_msg !=='undefined' && success_msg.length> 0) { %>
        <div class="alert alert-success">
            <%= success_msg %>
        </div>
        <% } %>

            <% if(typeof error_msg !=='undefined' && error_msg.length> 0) { %>
                <div class="alert alert-danger">
                    <%= error_msg %>
                </div>
                <% } %>


                    <%- include('../../public/components/header.html') %>
                        <h1 class="title">Administración Manual de Estados</h1>

                        <div class="container">

                            <div class="table-container">
                                <h2>Habitaciones</h2>
                                <table>
                                    <tr>
                                        <th class="short-column">ID Habitación</th>
                                        <th class="short-column">Estado Actual</th>
                                        <th class="medium-column">Nuevo Estado</th>
                                        <th class="medium-column">Acción</th>
                                    </tr>
                                    <% rooms.forEach(room=> { %>
                                        <tr>
                                            <td>
                                                <%= room.id_habitacion %>
                                            </td>
                                            <td>
                                                <%= room.estado %>
                                            </td>
                                            <td>
                                                <form action="/updateRoomState" method="POST"
                                                    class="form-room-update"
                                                    data-room-id="<%= room.id_habitacion %>">
                                                    <input type="hidden" name="id_habitacion"
                                                        value="<%= room.id_habitacion %>">
                                                    <select name="estado">
                                                        <option value="disponible" <%=room.estado=='disponible' ? 'selected' : '' %>>disponible
                                                        </option>
                                                        <option value="ocupada" <%=room.estado=='ocupada' ? 'selected' : '' %>>ocupada
                                                        </option>
                                                        <option value="mantenimiento" <%=room.estado=='mantenimiento' ? 'selected' : '' %>>mantenimiento
                                                        </option>
                                                    </select>
                                            </td>
                                            <td>
                                                <button type="submit">Actualizar</button>
                                                </form>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </table>
                            </div>

                            <div class="table-container">
                                <h2>Reservas</h2>
                                <table>
                                    <tr>
                                        <th class="short-column">ID Reserva</th>
                                        <th class="medium-column">ID Habitación</th>
                                        <th class="medium-column">Estado Actual</th>
                                        <th>Nuevo Estado</th>
                                        <th>Acción</th>
                                    </tr>
                                    <% reservations.forEach(reservation=> { %>
                                        <tr>
                                            <td>
                                                <%= reservation.id_reserva %>
                                            </td>
                                            <td>
                                                <%= reservation.id_habitacion %>
                                            </td>
                                            <td>
                                                <%= reservation.estado %>
                                            </td>
                                            <td>
                                                <form action="/updateReservationState" method="POST"
                                                    class="form-reservation-update"
                                                    data-reservation-id="<%= reservation.id_reserva %>">
                                                    <select name="estado" required>
                                                        <option value="" disabled selected>Seleccione un estado</option>
                                                        <option value="activa" <%=reservation.estado=='activa'
                                                            ? 'selected' : '' %>>activa</option>
                                                        <option value="reservada" <%=reservation.estado=='reservada'
                                                            ? 'selected' : '' %>>reservada</option>
                                                        <option value="cancelada" <%=reservation.estado=='cancelada'
                                                            ? 'selected' : '' %>>cancelada</option>
                                                        <option value="pre-reservada"
                                                            <%=reservation.estado=='pre-reservada' ? 'selected' : '' %>
                                                            >pre-reservada</option>
                                                        <option value="finalizada" <%=reservation.estado=='finalizada'
                                                            ? 'selected' : '' %>>finalizada</option>
                                                        <option value="mantenimiento"
                                                            <%=reservation.estado=='mantenimiento' ? 'selected' : '' %>
                                                            >mantenimiento</option>
                                                    </select>
                                                    <input type="hidden" name="id_reserva"
                                                        value="<%= reservation.id_reserva %>">
                                            </td>
                                            <td>
                                                <button type="submit">Actualizar</button>
                                                </form>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </table>
                            </div>
                        </div>

                        <script>
                            document.addEventListener('submit', function(e) {
                                var form = e.target.closest('.form-room-update');
                                if (form) {
                                    e.preventDefault();
                                    var roomId = form.getAttribute('data-room-id');
                                    Swal.fire({
                                        title: 'Confirmar',
                                        text: '¿Estás seguro de querer modificar el estado de la habitación #' + roomId + '?',
                                        icon: 'warning',
                                        showCancelButton: true,
                                        confirmButtonText: 'Sí, actualizar',
                                        cancelButtonText: 'No, cancelar'
                                    }).then((result) => {
                                        if (result.isConfirmed) {
                                            form.submit();
                                        }
                                    });
                                    return;
                                }
                                form = e.target.closest('.form-reservation-update');
                                if (form) {
                                    e.preventDefault();
                                    var reservationId = form.getAttribute('data-reservation-id');
                                    Swal.fire({
                                        title: 'Confirmar',
                                        text: '¿Estás seguro de querer modificar el estado de la reserva #' + reservationId + '?',
                                        icon: 'warning',
                                        showCancelButton: true,
                                        confirmButtonText: 'Sí, actualizar',
                                        cancelButtonText: 'No, cancelar'
                                    }).then((result) => {
                                        if (result.isConfirmed) {
                                            form.submit();
                                        }
                                    });
                                }
                            });
                        </script>
    <script src="../js/csrf-injector.js"></script>
</body>

</html>