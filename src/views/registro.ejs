<!DOCTYPE html>
<html lang="es">
  <head>
    <title>Posada | Reservaci처n</title>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="shortcut icon" href="../img/favicon.png" type="image/x-icon" />
    <link rel="stylesheet" href="../css/datatables.css" />
    <link rel="stylesheet" href="../css/main.css" />
    <link rel="stylesheet" href="../css/responsive-base.css" />
    <link rel="stylesheet" href="../css/navbar.css" />
    <link rel="stylesheet" href="../css/reservas.css" />
    <link rel="stylesheet" href="../css/copyright.css" />
    <link rel="preload" href="../img/beach.webp" as="image" />

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.12.4/dist/sweetalert2.all.min.js"></script>  
      <meta name="csrf-token" content="<%= csrfToken %>">
</head>
  <body>
    <!-- Header -->
    <header class="topheader" id="topheader">
      <div class="topnav">
        <div class="logo"></div>      
        <%- include('../../public/components/navbar.html', { pageTitle: 'Reservaci처n de Clientes' }) %>
      </div>
    </header>
    <!-- Reservaci처n -->
    <section class="contact" id="contact">
      <div class="contact-container">
        <div class="contactInfo"></div>
        <form
          action="/registro"
          method="POST"

        >
          <div class="contactForm">
            <h2>Reservaci처n de Clientes</h2>
            <div class="formBox">
              <div class="inputBox w50">
                <input
                  type="text"
                  name="nombre"
                  title="Solo acepta letras, espacios en blanco, acentos y puntos"
                  pattern="^[a-zA-Z찼챕챠처첬횁횋횒횙횣체횥챰횗. ]{1,15}$"
                  required
                  id="nombre"
                />
                <span>Nombre</span>
              </div>
              <div class="inputBox w50">
                <input
                  type="text"
                  name="apellido"
                  title="Solo acepta letras, espacios en blanco, acentos y puntos"
                  pattern="^[a-zA-Z찼챕챠처첬횁횋횒횙횣체횥챰횗. ]{1,15}$"
                  required
                  id="apellido"
                />
                <span>Apellido</span>
              </div>
              <div class="inputBox w50">
                <div class="prefix-group">
                  <select id="cedula_prefix" data-prefix="cedula">
                    <option value="V-">V-</option>
                    <option value="E-">E-</option>
                  </select>
                  <input
                    type="text"
                    name="cedula"
                    id="cedula"
                    data-format="cedula"
                    required
                  />
                </div>
                <span>C챕dula</span>
              </div>
              <div class="inputBox w50">
                <input
                  type="email"
                  name="correo"
                  title="Email incorrecto"
                  pattern="^[\w.+\-]+@[A-Za-z\d.\-]+\.[A-Za-z]{2,15}$"
                  required
                  id="correo"
                />
                <span>Correo Electr처nico</span>
              </div>
              <div class="inputBox w50">
                <div class="prefix-group">
                  <select id="telefono_prefix" data-prefix="telefono">
                    <option value="+58">+58</option>
                    <option value="+1">+1</option>
                  </select>
                  <input
                    type="text"
                    name="telefono"
                    id="telefono"
                    data-format="telefono"
                    required
                  />
                </div>
                <span>N첬mero de tel챕fono</span>
              </div>
              <div class="inputBox w50">
                <input
                  type="text"
                  name="procedencia"
                  title="Solo acepta letras, espacios en blanco, acentos y puntos"
                  pattern="^[a-zA-Z찼챕챠처첬횁횋횒횙횣체횥챰횗. ]{1,15}$"
                  required
                  id="procedencia"
                />
                <span>Procedencia</span>
              </div>
              <div class="inputBox w50">
                <input
                  type="number"
                  name="personas"
                  title="Solo acepta n첬meros y hasta un m찼ximo de 2 caracteres"
                  pattern="^[0-9]{1,2}$"
                  required
                  id="personas"
                />
                <span>N첬mero de Personas</span>
              </div>
              <div class="inputBox w50">
                <input
                  type="number"
                  name="habitacion"
                  title="Solo acepta n첬meros y hasta un m찼ximo de 2 caracteres"
                  pattern="^[0-9]{1,2}$"
                  required
                  id="habitacion"
                />
                <span>Habitaci처n Asignada</span>
              </div>
              <div class="inputBox w50">
                <input type="date" name="entrada" required id="fechaEntrada" />
                <span>Fecha de Entrada</span>
              </div>
              <div class="inputBox w50">
                <input type="date" name="salida" required id="fechaSalida" />
                <span>Fecha de Salida</span>
              </div>

              <div class="inputBox w50">
                <input
                  type="number"
                  name="monto"
                  step="0.01"
                  required
                  id="monto"
                />
                <span>Monto Abonado</span>
              </div>

              <div class="inputBox w50">
                <input
                  type="date"
                  name="fecha_transaccion"
                  required
                  id="fechaTransaccion"
                />
                <span>Fecha de Transacci처n</span>
              </div>

              <fieldset>
                <legend>M챕todos de Pago:</legend>
                <label
                  ><input
                    type="checkbox"
                    name="metodos_pago"
                    value="efectivo"
                  />Efectivo</label
                >
                <label
                  ><input
                    type="checkbox"
                    name="metodos_pago"
                    value="divisas"
                  />Divisas</label
                >
                <label
                  ><input
                    type="checkbox"
                    name="metodos_pago"
                    value="debito"
                  />D챕bito</label
                >
                <label
                  ><input
                    type="checkbox"
                    name="metodos_pago"
                    value="credito"
                  />Cr챕dito</label
                >
              </fieldset>

              <div class="inputBox w50 button-group">
                <input type="submit" value="Reservar" />
                <a href="/menu" class="btn-back" data-action="volver">Volver</a>
              </div>
            </div>
          </div>
        </form>
      </div>
    </section>
    <!-- Footer -->
    <%- include('../../public/components/footer.html') %>

    <script src="https://use.fontawesome.com/698a367122.js"></script>
    <script src="../js/formValidation.js"></script>
    <script src="../js/validaFecha.js"></script>
    <script src="../js/formatInputs.js"></script>
    <script>
      // Mostrar alertas de 챕xito o error
      document.addEventListener("DOMContentLoaded", function () {
        const urlParams = new URLSearchParams(window.location.search);
        const success = urlParams.get("success");
        const error = urlParams.get("error");

        if (success) {
          Swal.fire({
            title: "징횋xito!",
            text: "Cliente registrado exitosamente!",
            icon: "success",
            confirmButtonText: "OK",
          });
        } else if (error) {
          Swal.fire({
            title: "징Error!",
            text: decodeURIComponent(error),
            icon: "error",
            confirmButtonText: "OK",
          });
        }
      });
    </script>
      <script>
        document.querySelector('.contactForm form').addEventListener('submit', function(e) {
          if (!validarFormulario()) e.preventDefault();
        });
        document.addEventListener('click', function(e) {
          var btn = e.target.closest('[data-action="volver"]');
          if (btn) { e.preventDefault(); history.back(); }
        });
      </script>
      <script src="../js/csrf-injector.js"></script>
</body>
</html>
