<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="shortcut icon" href="../img/favicon.png" type="image/x-icon" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <link rel="stylesheet" href="../css/login.css" />
    <link rel="stylesheet" href="../css/copyright.css" />
    <link rel="preload" href="../img/posadaLobby.webp" as="image" />
    <title>Restablecer Contraseña | Posada</title>
</head>

<body>
    <%- include('../../public/components/login.html') %>

        <div class="fondo">
            <div class="contenedor-form login">
                <h2>Restablecer Contraseña</h2>
                <p class="instruccion">Ingresa tu nueva contraseña.</p>
                <form action="/reset-password" method="POST">
                    <input type="hidden" name="token" value="<%= token %>" />

                    <div class="contenedor-input">
                        <span class="icono"><i class="fa-solid fa-lock"></i></span>
                        <input type="password" required name="password" autocomplete="new-password" id="password" />
                        <label for="password">Nueva Contraseña</label>
                    </div>

                    <div class="contenedor-input">
                        <span class="icono"><i class="fa-solid fa-lock"></i></span>
                        <input type="password" required name="confirmPassword" autocomplete="new-password"
                            id="confirmPassword" />
                        <label for="confirmPassword">Confirmar Contraseña</label>
                    </div>

                    <button type="submit" class="btn">Cambiar Contraseña</button>
                </form>
            </div>
        </div>
        <footer class="footer">
            <p>
                Copyright &copy; Elaborado por
                <a href="https://cycs.netlify.app" target="_blank">Carlos Colmenares A.</a> | Derechos Reservados
            </p>
        </footer>

        <!-- Sweetalert 2 -->
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.12.4/dist/sweetalert2.all.min.js"></script>

        <!-- Mensajes de alerta personalizados -->
        <% if (typeof alert !="undefined" ) { %>
            <script>
                Swal.fire({
                    title: "<%= alertTitle %>",
                    text: "<%= alertMessage %>",
                    icon: "<%= alertIcon %>",
                    showConfirmButton: true,
                    timer: 3000,
                }).then(() => {
                    window.location.href = "/<%= ruta %>";
                });
            </script>
            <% } %>

                <!-- Validación de contraseñas -->
                <script>
                    document.querySelector('form').addEventListener('submit', function (event) {
                        const password = document.getElementById('password').value;
                        const confirmPassword = document.getElementById('confirmPassword').value;

                        if (password !== confirmPassword) {
                            event.preventDefault();
                            Swal.fire({
                                title: 'Error',
                                text: 'Las contraseñas no coinciden',
                                icon: 'error',
                                showConfirmButton: true
                            });
                        }

                        if (password.length < 8) {
                            event.preventDefault();
                            Swal.fire({
                                title: 'Error',
                                text: 'La contraseña debe tener al menos 8 caracteres',
                                icon: 'error',
                                showConfirmButton: true
                            });
                        }
                    });
                </script>
</body>

</html>