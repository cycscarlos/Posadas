<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Administración del Chatbot</title>
    <link rel="shortcut icon" href="../img/favicon.png" type="image/x-icon" />

    <!-- Fontawesome v6.6.0 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css"
        integrity="sha512-Kc323vGBEqzTmouAECnVceyQqyqdsSiqLQISBL29aUW4U/M7pSPA/gEUZQqv1cwx4OnYxTxve5UMg5GT6L4JJg=="
        crossorigin="anonymous" referrerpolicy="no-referrer" />

    <!-- Bootstrap 5.3.3 CSS -->
    <link rel="stylesheet" href="../bootstrap/css/bootstrap.min.css" />

    <!-- Datatables CSS Local Installation -->
    <link rel="stylesheet" href="../downloadButtons/datatables.css" />
    <link href="../downloadButtons/datatables.min.css" rel="stylesheet" />

    <!-- CSS personalizado -->
    <link rel="stylesheet" href="../css/datatables.css" />
    <link rel="stylesheet" href="../css/main.css" />
    <link rel="stylesheet" href="../css/responsive-base.css" />
    <link rel="stylesheet" href="../css/navbar.css" />
    <link rel="stylesheet" href="../css/adminChatbot.css" />
    <meta name="csrf-token" content="<%= csrfToken %>">
</head>

<body class="body">
    <header class="topheader" id="topheader">
        <div class="topnav">
            <div class="logo"></div>
            <%- include('../../public/components/navbar.html') %>
        </div>
    </header>

    <div class="container">

        <h1>Administración del Chatbot</h1>

        <!-- Sección: Precios de Habitaciones -->
        <h2><i class="fas fa-bed"></i> Precios de Habitaciones</h2>
        <div class="table-responsive">
            <table id="tablaPrecios" class="table table-striped table-bordered table-hover" style="width: 100%">
                <thead class="thead-bg">
                    <tr>
                        <th class="text-center">#</th>
                        <th class="text-center">Tipo</th>
                        <th class="text-center">Capacidad</th>
                        <th class="text-center">Precio (Bs.)</th>
                        <th class="text-center">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    <% habitaciones.forEach(function(h) { %>
                        <tr data-id="<%= h.id_habitacion %>">
                            <td class="text-center"><%= h.id_habitacion %></td>
                            <td class="text-center"><%= h.tipo_habitacion %></td>
                            <td class="text-center"><%= h.capacidad %></td>
                            <td class="text-center">
                                <input type="number" step="0.01" min="0" class="precio-input form-control d-inline-block"
                                    value="<%= h.precio !== null ? h.precio : '' %>"
                                    data-id="<%= h.id_habitacion %>"
                                    placeholder="Sin precio" />
                            </td>
                            <td class="text-center">
                                <button class="btn btn-outline-info btn-guardar-precio" data-id="<%= h.id_habitacion %>">
                                    <i class="fas fa-save"></i> Guardar
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <!-- Sección: Promociones -->
        <h2><i class="fas fa-tags"></i> Promociones</h2>

        <form id="formPromocion" class="promocion-form">
            <div class="form-group">
                <label for="titulo">Título *</label>
                <input type="text" id="titulo" name="titulo" required />
            </div>
            <div class="form-group">
                <label for="descripcion">Descripción</label>
                <textarea id="descripcion" name="descripcion"></textarea>
            </div>
            <div class="form-group">
                <label for="fecha_inicio">Fecha de Inicio</label>
                <input type="date" id="fecha_inicio" name="fecha_inicio" />
            </div>
            <div class="form-group">
                <label for="fecha_fin">Fecha de Fin</label>
                <input type="date" id="fecha_fin" name="fecha_fin" />
            </div>
            <div class="promocion-checkbox">
                <input type="checkbox" id="activo" name="activo" value="1" checked />
                <label for="activo">Activo</label>
            </div>
            <button type="submit">Agregar Promoción</button>
        </form>

        <hr style="margin: 2rem 0" />

        <div class="table-responsive">
            <table id="tablaPromociones" class="table table-striped table-bordered table-hover" style="width: 100%">
                <thead class="thead-bg">
                    <tr>
                        <th class="text-center">ID</th>
                        <th class="text-center">Título</th>
                        <th class="text-center">Descripción</th>
                        <th class="text-center">Inicio</th>
                        <th class="text-center">Fin</th>
                        <th class="text-center">Estado</th>
                        <th class="text-center">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    <% promociones.forEach(function(p) { %>
                        <tr data-id="<%= p.id_promocion %>">
                            <td class="text-center"><%= p.id_promocion %></td>
                            <td><%= p.titulo %></td>
                            <td><%= p.descripcion || '-' %></td>
                            <td class="text-center"><%= p.fecha_inicio ? new Date(p.fecha_inicio).toLocaleDateString('es-VE') : '-' %></td>
                            <td class="text-center"><%= p.fecha_fin ? new Date(p.fecha_fin).toLocaleDateString('es-VE') : '-' %></td>
                            <td class="text-center">
                                <% if (p.activo) { %>
                                    <span class="activo-badge">Activo</span>
                                <% } else { %>
                                    <span class="inactivo-badge">Inactivo</span>
                                <% } %>
                            </td>
                            <td class="text-center">
                                <button class="btn btn-outline-danger btn-eliminar-promocion" data-id="<%= p.id_promocion %>">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    <% }) %>

                </tbody>
            </table>
        </div>

    </div>

    <!-- Bootstrap v5.3.3 -->
    <script src="../bootstrap/js/bootstrap.min.js"></script>

    <!-- JQuery v3.7.1 -->
    <script src="../jquery/js/jquery-3.7.1.min.js"></script>

    <!-- Datatables JS Local Installation -->
    <script src="../downloadButtons/datatables.js"></script>
    <script src="../downloadButtons/datatables.min.js"></script>

    <!-- Sweetalert 2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.12.4/dist/sweetalert2.all.min.js"></script>

    <script>
        $(document).ready(function () {
            $("#tablaPrecios").DataTable({
                language: { emptyTable: "No hay habitaciones registradas." }
            });
            $("#tablaPromociones").DataTable({
                language: { emptyTable: "No hay promociones registradas." }
            });
        });

        // Guardar precio
        document.addEventListener('click', function (e) {
            const btn = e.target.closest('.btn-guardar-precio');
            if (!btn) return;
            const id = btn.getAttribute('data-id');
            const input = document.querySelector('.precio-input[data-id="' + id + '"]');
            const precio = input ? input.value : '';
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

            fetch('/adminChatbot/precios/' + id, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ precio: precio })
            })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (data.success) {
                        Swal.fire({ icon: 'success', title: data.message, showConfirmButton: false, timer: 1500 });
                    } else {
                        Swal.fire({ icon: 'error', title: 'Error', text: data.message });
                    }
                })
                .catch(function () {
                    Swal.fire({ icon: 'error', title: 'Error', text: 'Error al conectar con el servidor.' });
                })
                .finally(function () {
                    btn.disabled = false;
                    btn.innerHTML = '<i class="fas fa-save"></i> Guardar';
                });
        });

        // Agregar promoción
        document.getElementById('formPromocion').addEventListener('submit', function (e) {
            e.preventDefault();
            const form = this;
            const data = {
                titulo: form.titulo.value.trim(),
                descripcion: form.descripcion.value.trim(),
                fecha_inicio: form.fecha_inicio.value || null,
                fecha_fin: form.fecha_fin.value || null,
                activo: form.activo.checked ? 1 : 0
            };

            if (!data.titulo) {
                Swal.fire({ icon: 'warning', title: 'El título es requerido.' });
                return;
            }

            const btn = form.querySelector('button[type="submit"]');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

            fetch('/adminChatbot/promociones', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (data.success) {
                        Swal.fire({ icon: 'success', title: data.message, showConfirmButton: false, timer: 1500 });
                        setTimeout(function () { location.reload(); }, 1500);
                    } else {
                        Swal.fire({ icon: 'error', title: 'Error', text: data.message });
                    }
                })
                .catch(function () {
                    Swal.fire({ icon: 'error', title: 'Error', text: 'Error al conectar con el servidor.' });
                })
                .finally(function () {
                    btn.disabled = false;
                    btn.innerHTML = 'Agregar Promoción';
                });
        });

        // Eliminar promoción
        document.addEventListener('click', function (e) {
            const btn = e.target.closest('.btn-eliminar-promocion');
            if (!btn) return;
            const id = btn.getAttribute('data-id');

            Swal.fire({
                title: '¿Confirmas eliminar la promoción?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Eliminar',
                cancelButtonText: 'Cancelar'
            }).then(function (result) {
                if (!result.isConfirmed) return;
                fetch('/adminChatbot/promociones/delete/' + id, { method: 'POST' })
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        if (data.success) {
                            Swal.fire({ icon: 'success', title: data.message, showConfirmButton: false, timer: 1500 });
                            $('#tablaPromociones').DataTable().row($('tr[data-id="' + id + '"]')).remove().draw();
                        } else {
                            Swal.fire({ icon: 'error', title: 'Error', text: data.message });
                        }
                    })
                    .catch(function () {
                        Swal.fire({ icon: 'error', title: 'Error', text: 'Error al conectar con el servidor.' });
                    });
            });
        });
    </script>
    <script src="../js/csrf-injector.js"></script>
    <script src="../js/chatbot.js"></script>
</body>

</html>
