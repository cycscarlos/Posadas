# Configuración de entorno para el sistema Posadas
# Copie este archivo a .env y configure los valores adecuados

# Entorno de la aplicación (development, production)
NODE_ENV=development

# Puerto para el servidor
PORT=3000

# Configuración de la base de datos
DB_HOST=localhost
DB_USER=cycscarlos
DB_PASSWORD=Best_001*
DB_NAME=posada_db
DB_PORT=3306

# Secreto para firmar las sesiones (IMPORTANTE: cambie esto por una cadena aleatoria larga en producción)
# Puede generar una clave segura con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=proyecto_posadas

# Configuración de tiempo de vida de sesiones (en milisegundos)
# 3600000 = 1 hora
SESSION_LIFETIME=3600000

# URLs para servicios de terceros (si se utilizan)
API_URL=https://api.example.com

# =========================================
# CONFIGURACIÓN DE CORREO ELECTRÓNICO
# =========================================

# Configuración original para envío de campañas publicitarias
# NO MODIFICAR - Requerido por ctrl_envioEmail.js
EMAIL_USER=cycs.instalacion@gmail.com
EMAIL_PASS=pcsi ktgk cjzg dvsk

# Configuración para sistema de recuperación de contraseñas
# Utilizando la misma cuenta para mantener consistencia
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=cycs.instalacion@gmail.com
MAIL_PASSWORD=pcsi ktgk cjzg dvsk
MAIL_FROM=cycs.instalacion@gmail.com

# Si usas otro proveedor (ejemplo: Outlook/Hotmail)
# MAIL_HOST=smtp.office365.com
# MAIL_PORT=587
# MAIL_USER=tu_correo@outlook.com
# MAIL_PASSWORD=tu_contraseña
# MAIL_FROM=tu_correo@outlook.com

# Configuración de WhatsApp (si se utiliza)
WHATSAPP_API_KEY=your_whatsapp_api_key

# Configuración de seguridad adicional
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_MS=900000  # 15 minutos en milisegundos 