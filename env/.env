# =========================================
# CONFIGURACIÓN DE WHATSAPP BUSINESS API
# =========================================
# Estos valores se obtienen del Meta Developer Portal: https://developers.facebook.com/apps/
# Para obtener estos valores:
# 1. Cree una app en Meta for Developers
# 2. Agregue la capacidad de WhatsApp a su app
# 3. Configure un número de teléfono de prueba o de producción

# Versión de la API (se recomienda v17.0 o superior)
WHATSAPP_API_VERSION=v17.0

# ID del número de teléfono (se encuentra en WhatsApp > Configuration > Phone numbers)
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# Token de acceso permanente (Sistema > Tokens de acceso)
WHATSAPP_ACCESS_TOKEN=EAABx...token_largo_aqui...xyz123

# ID de la cuenta de empresa (Business Settings > Accounts)
WHATSAPP_BUSINESS_ACCOUNT_ID=1234567890

# Nombre de la plantilla aprobada (si se utilizan plantillas)
WHATSAPP_TEMPLATE_NAME_ES=posada_promocion

# =========================================
# CONFIGURACIÓN DE SEGURIDAD
# =========================================
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_MS=900000  # 15 minutos en milisegundos 