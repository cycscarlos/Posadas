<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gestión de Usuarios</title>
    <link rel="shortcut icon" href="../img/favicon.png" type="image/x-icon" />

    <!-- Fontawesome v6.6.0 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css"
        integrity="sha512-Kc323vGBEqzTmouAECnVceyQqyqdsSiqLQISBL29aUW4U/M7pSPA/gEUZQqv1cwx4OnYxTxve5UMg5GT6L4JJg=="
        crossorigin="anonymous" referrerpolicy="no-referrer" />

    <!-- Bootstrap 5.3.3 CSS -->
    <link rel="stylesheet" href="../bootstrap/css/bootstrap.min.css" />

    <!-- Datatables CSS Local Installation -->
    <link rel="stylesheet" href="../downloadButtons/datatables.css" />
    <link href="../downloadButtons/datatables.min.css" rel="stylesheet" />

    <!-- CSS personalizado -->
    <link rel="stylesheet" href="../css/datatables.css" />
    <link rel="stylesheet" href="../css/main.css" />
    <link rel="stylesheet" href="../css/navbar.css" />
    <link rel="stylesheet" href="../css/userManagement.css" />
    <meta name="csrf-token" content="<%= csrfToken %>">
</head>

<body class="body">
    <header class="topheader" id="topheader">
        <div class="topnav">
            <div class="logo"></div>
            <%- include('../../public/components/navbar.html') %>
        </div>
    </header>

    <div class="container">
        <h1>Gestión de Usuarios</h1>

        <h2>Agregar Usuario</h2>
        <form id="registerForm" action="/register" method="POST">
            <div class="form-group">
                <label for="username">Nombre de Usuario:</label>
                <input type="text" id="username" name="username" required />
            </div>
            <div class="form-group">
                <label for="password">Contraseña:</label>
                <input type="password" id="password" name="password" required />
            </div>
            <div class="form-group">
                <label for="fullname">Nombre Completo:</label>
                <input type="text" id="fullname" name="fullname" required />
            </div>
            <div class="form-group">
                <label for="correo">Correo Electrónico:</label>
                <input type="email" id="correo" name="correo" required />
            </div>
            <div class="form-group">
                <label for="rol">Rol:</label>
                <input type="text" id="rol" name="rol" required />
            </div>
            <button type="submit">Registrar</button>
        </form>

        <!-- Lista de Usuarios -->
        <h2>Lista de Usuarios</h2>
        <div class="table-responsive">
            <table id="tablaUsuarios" class="table table-striped table-bordered table-hover" style="width: 100%">
                <thead class="thead-bg">
                    <tr>
                        <th class="text-center">ID</th>
                        <th class="text-center">Nombre de Usuario</th>
                        <th class="text-center">Nombre Completo</th>
                        <th class="text-center">Correo</th>
                        <th class="text-center">Rol</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(user=> { %>
                        <tr data-id="<%= user.id %>">
                            <td class="text-center">
                                <%= user.id %>
                            </td>
                            <td class="text-center">
                                <%= user.username %>
                            </td>
                            <td class="text-center">
                                <%= user.fullname %>
                            </td>
                            <td class="text-center">
                                <%= user.correo %>
                            </td>
                            <td class="text-center">
                                <%= user.rol %>
                            </td>
                            <td class="text-center">
                                <a onclick="editar('<%= user.id %>', '<%= user.username %>', '<%= user.fullname %>', '<%= user.correo %>', '<%= user.rol %>')"
                                    class="btn btn-outline-info link1" data-tooltip="Editar">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a onclick="confirmar('<%= user.id %>')" class="btn btn-outline-danger link2"
                                    data-tooltip="Eliminar">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Bootstrap v5.3.3 -->
    <script src="../bootstrap/js/bootstrap.min.js"></script>

    <!-- JQuery v3.7.1 -->
    <script src="../jquery/js/jquery-3.7.1.min.js"></script>

    <!-- Datatables JS Local Installation -->
    <script src="../downloadButtons/datatables.js"></script>
    <script src="../downloadButtons/datatables.min.js"></script>

    <!-- Sweetalert 2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.12.4/dist/sweetalert2.all.min.js"></script>

    <!-- Initialising DataTables -->
    <script>
        $(document).ready(function () {
            // Inicializar DataTable  
            $("#tablaUsuarios").DataTable();
        });

        function confirmar(id) {
            Swal.fire({
                title: "¿Confirmas eliminar el registro?",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                confirmButtonText: "Confirmar",
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/delete/${id}`, {
                        method: 'POST'
                    })
                        .then(response => response.json())
                        .then(result => {
                            if (result.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Usuario eliminado exitosamente',
                                    showConfirmButton: false,
                                    timer: 1500
                                });
                                $(`#tablaUsuarios tr[data-id="${id}"]`).remove();
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error al eliminar usuario',
                                    text: result.message,
                                    confirmButtonText: 'Aceptar'
                                });
                            }
                        })
                        .catch(error => {
                            console.error('Error:', error);
                            Swal.fire({
                                icon: 'error',
                                title: 'Error al eliminar usuario',
                                text: 'Ocurrió un error inesperado. Por favor, inténtalo de nuevo.',
                                confirmButtonText: 'Aceptar'
                            });
                        });
                }
            });
        }

        function editar(id, username, fullname, correo, rol) {
            Swal.fire({
                title: 'Editar Usuario',
                html: `  
                    <input id="swal-input1" class="swal2-input" value="${username}" placeholder="Nombre de Usuario">  
                    <input id="swal-input2" class="swal2-input" value="${fullname}" placeholder="Nombre Completo">
                    <input id="swal-input3" class="swal2-input" value="${correo}" placeholder="Correo Electrónico">
                    <input id="swal-input4" class="swal2-input" value="${rol}" placeholder="Rol">  
                    <input type="password" id="swal-input5" class="swal2-input" placeholder="Nueva Contraseña (opcional)">  
                `,
                focusConfirm: false,
                preConfirm: () => {
                    const newUsername = document.getElementById('swal-input1').value.trim();
                    const newFullname = document.getElementById('swal-input2').value.trim();
                    const newCorreo = document.getElementById('swal-input3').value.trim();
                    const newRol = document.getElementById('swal-input4').value.trim();
                    const newPassword = document.getElementById('swal-input5').value.trim();

                    if (!newUsername || !newFullname || !newRol) {
                        Swal.showValidationMessage('Por favor, completa todos los campos requeridos.');
                        return false; // Cancelar la confirmación si hay campos vacíos  
                    }

                    return { username: newUsername, fullname: newFullname, correo: newCorreo, rol: newRol, password: newPassword };
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`/update/${id}`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(result.value)
                    })
                        .then(response => response.json())
                        .then(result => {
                            if (result.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Usuario actualizado exitosamente',
                                    showConfirmButton: false,
                                    timer: 1500
                                });

                                // Actualizar la fila en la tabla  
                                const row = $(`#tablaUsuarios tr[data-id="${id}"]`);
                                row.find('td:eq(1)').text(result.value.username);
                                row.find('td:eq(2)').text(result.value.fullname);
                                row.find('td:eq(3)').text(result.value.correo);
                                row.find('td:eq(4)').text(result.value.rol);
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error al actualizar usuario',
                                    text: result.message,
                                    confirmButtonText: 'Aceptar'
                                });
                            }
                        })
                        .catch(error => {
                            console.error('Error:', error);
                            Swal.fire({
                                icon: 'error',
                                title: 'Error al actualizar usuario',
                                text: 'Ocurrió un error inesperado. Por favor, inténtalo de nuevo.',
                                confirmButtonText: 'Aceptar'
                            });
                        });
                }
            });
        }

        document.getElementById('registerForm').addEventListener('submit', function (event) {
            event.preventDefault(); // Prevenir el envío del formulario  

            // Obtener los datos del formulario  
            const formData = new FormData(event.target);
            const data = Object.fromEntries(formData.entries());

            // Enviar la solicitud al servidor  
            fetch('/register', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(data)
            })
                .then(response => response.json())
                .then(result => {
                    if (result.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Usuario registrado exitosamente',
                            showConfirmButton: false,
                            timer: 1500
                        });
                        event.target.reset();
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error al registrar usuario',
                            text: result.message,
                            confirmButtonText: 'Aceptar'
                        });
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    Swal.fire({
                        icon: 'error',
                        title: 'Error al registrar usuario',
                        text: 'Ocurrió un error inesperado. Por favor, inténtalo de nuevo.',
                        confirmButtonText: 'Aceptar'
                    });
                });
        });  
    </script>
    <script src="../js/csrf-injector.js"></script>
</body>

</html>