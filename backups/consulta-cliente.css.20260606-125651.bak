.form {
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 1rem;
  width: 350px;
  height: 400px;
  background-color: rgba(
    255,
    255,
    255,
    0.7
  ); /* Cambia la opacidad según sea necesario */
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
  border-radius: 5px;
  z-index: 1; /* Asegúrate de que el formulario esté encima */
}

.title {
  color: var(--login-color);
  text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
  font-size: 2.5rem;
  margin-top: 2rem;
}

.inputBx {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 1rem;
}

.inputBx label {
  font-size: 1.2rem;
  color: var(--login-color);
  background-color: rgba(255, 255, 255, 0.5);
  padding: 5px 10px;
  border-radius: 5px;
}

.inputBx input,
.btn {
  padding: 0.5rem;
  margin: 1.5rem;
  border: none;
  border-radius: 5px;
  background-color: rgba(
    255,
    255,
    255,
    0.8
  ); /* Cambia la opacidad para los inputs */
  box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
  font-size: 1rem;
}

.btn {
  width: 50%;
  background-color: var(--login-color);
  color: white;
  font-size: 1rem;
  cursor: pointer;
}

.btn:hover {
  transform: scale(1.1);
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
}

.inputBx {
  margin-bottom: 15px; /* Espaciado entre campos */
}

