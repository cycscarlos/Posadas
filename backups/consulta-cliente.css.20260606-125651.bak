* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;

  --primary-color: aliceblue;
  --secondary-color: #9d8d6c;
  --base-color: #ffffff;
  --login-color: #f6a700;
}

.navbar ul li {
  background-color: var(--login-color);
}

.navbar ul a {
  color: var(--base-color);
  font-weight: 500;
}

img {
  display: block;
  max-width: 100%;
  height: auto;
}

.container {
  width: 100%;
  height: 100vh;
  position: relative; /* Necesario para el posicionamiento del pseudo-elemento */
  overflow: hidden; /* Para que no se salga el efecto difuminado */
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  border: none;
  outline: none;
  text-align: center;
  font-family: var(--font-body);
}

/* Pseudo-elemento para el fondo con desenfoque y oscurecimiento */
.container::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url("../img/playa3.webp") repeat center center/cover;
  background-size: cover;
  background-position: center;
  filter: brightness(0.9) blur(0.1px); /* Oscurecimiento y desenfoque 
  /*filter: brightness(0.5) blur(1.5px); /* Oscurecimiento y desenfoque */
  border: none;
  outline: none;
  z-index: 0; /* Enfocar más en el fondo */
}

