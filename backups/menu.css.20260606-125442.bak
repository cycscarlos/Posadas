:root {
  --navbar-color: #9d8d6c;
  --login-color: #f6a700;
  --white-color: #ffffff;
}
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

img {
  display: block;
  max-width: 100%;
  height: auto;
}

body {
  height: 100vh;
  overflow: hidden;
  /* Fondo de pantalla */
  background: url("../img/playa1.webp") no-repeat center center/cover;
  background-size: cover;
  background-position: center;
}

.topnav {
  display: flex;
  justify-content: end;
  align-items: flex-start;
  padding: 40px 40px 0 0;
  height: max-content;
}

.navbar ul li {
  background-color: var(--login-color);
}

.navbar ul a {
  color: white;
  font-weight: 500;
}

.container {
  display: flex;
  width: 100%;
  height: 100%;
  margin: 0;
  padding: 0;
  z-index: 1;
  /* background: url("../img/playa1.webp") no-repeat center center/cover;
  background-size: cover;
  background-position: center; */
  /* filter: brightness(0.75); */
}

.sidebar {
  width: 250px;
  background-color: rgba(44, 62, 80, 0.3);
  color: white;
  padding: 15px;
  box-sizing: border-box;
  overflow: hidden;
  z-index: 1;
}

.sidebar h2 {
  margin: 0 0 20px;
}

.sidebar ul {
  list-style-type: none;
  padding: 0;
}

.sidebar ul li {
  font-size: var(--step-0);
}

.sidebar ul > li {
  margin: 20px 0;
  position: relative;
  cursor: pointer;
}

.sidebar ul > li:hover {
  color: orange;
}

.sidebar ul li a {
  color: white;
  text-decoration: none;
  padding: 10px 15px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-radius: 5px;
  font-size: var(--step--1);
}

.sidebar ul li ul {
  list-style-type: none;
  padding-left: 10px;
  max-height: 0;
  overflow: hidden;
  /* transition: max-height 0.3s ease; */
  transition: max-height 1s ease;
}

.sidebar ul li ul.open {
  max-height: 200px;
  /* transition: max-height 0.3s ease; */
  transition: max-height 1s ease;
}

.sidebar ul li ul li {
  margin: 0;
}

.sidebar ul li ul li:nth-child(3) a span {
  text-align: center;
  /* position: absolute;
  top: 30px;
  right: 30px; */
}

.sidebar ul li ul li:nth-child(4) a span {
  position: absolute;
  top: 20px;
  right: 42px;
  /* right: 62px; */
}

.sidebar ul li ul li a span {
  text-align: left;
  font-size: smaller;
  font-style: italic;
  color: bisque;
}

.sidebar ul li ul li a:hover {
  background-color: #34495e;
  color: var(--login-color);
}

.toggle-icon {
  font-size: 8px;
}

.content {
  flex-grow: 1;
  padding: 20px;
  display: grid;
  grid-template-columns: repeat(2, 300px);
  gap: 5px;
  justify-content: center;
  align-items: center;
  height: 100%;
  overflow: hidden;
  z-index: 1;
}

.card {
  width: 200px;
  height: 200px;
  padding: 15px;
  border-radius: 5px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  background: transparent;
  border: 2px solid rgba(255, 255, 255, 0.5);
  border-radius: 20px;
  backdrop-filter: blur(20px);
  box-shadow: 0 0 30px rgba(0, 0, 0, 0.5);
  transition: all 0.5s ease;
}

.card h2 {
  margin: 0;
}

.card p {
  font-size: 14px;
  margin: 0;
}

.card a {
  /* color: var(--logotype-color); */
  color: whitesmoke;
  text-decoration: none;
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  cursor: pointer;
}

.card a span {
  font-size: var(--step-0);
  margin-top: 5px;
}

.card:hover {
  transform: translateY(-5px);
  box-shadow: 10px 10px 10px rgba(0, 0, 0, 0.5);
}

.card:hover h2 a {
  color: #7ad7f3;
}

@media (max-width: 768px) {
  .sidebar {
    width: 200px;
  }
  .content {
    grid-template-columns: 1fr;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    height: 70%;
    gap: 3rem;
  }
  .card {
    width: 100%;
    height: auto;
  }
  h2 {
    font-size: var(--step-1);
  }
}
